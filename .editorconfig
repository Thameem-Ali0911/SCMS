# EditorConfig — fixes the v1.3 finding: "AdminController.java has CRLF
# line endings while ComplaintController.java has LF — mixed line endings
# in the same project... this is the first team conflict." Most editors and
# IDEs (IntelliJ, VS Code) respect this file automatically with no plugin.
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_size = 4

[*.{js,jsx,ts,tsx,json,css,html,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
