# Copy this file to .env and fill in real values before running
# `docker compose up`. Never commit a real .env file — it's already in
# .gitignore.

# ── Database ──────────────────────────────────────────────────────────────
DB_NAME=scms_db
DB_PASS=root
DB_PORT=3306

# ── Backend / Security ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="change-me-to-a-strong-secret"

# Comma-separated list of frontend origins allowed to call this API.
# For the bundled docker-compose stack, the frontend is served from the
# same origin (via Nginx's /api proxy), so this only needs to be the public
# URL you actually visit in a browser.
CORS_ORIGINS=http://localhost:8080

# Set to "true" once you are running behind real HTTPS (a reverse proxy/load
# balancer terminating TLS, or TLS on the container itself). Keep "false"
# only for local http:// development.
COOKIE_SECURE=false
HSTS_ENABLED=false

# Comma-separated list of IP addresses of reverse proxies you trust to set
# X-Forwarded-For accurately. Leave empty if nothing sits in front of this
# stack besides the bundled Nginx container talking to it over the Docker
# network (X-Forwarded-For isn't needed in that topology — Nginx forwards
# the real client IP via X-Real-IP/X-Forwarded-For itself, but since
# clients can't reach the backend container directly, spoofing isn't
# possible regardless).
TRUSTED_PROXIES=

SPRING_PROFILES_ACTIVE=prod
BACKEND_PORT=8081
FRONTEND_PORT=8080

# ── Email notifications (optional) ─────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
