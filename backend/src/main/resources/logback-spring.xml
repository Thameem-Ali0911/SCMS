<?xml version="1.0" encoding="UTF-8"?>
<!--
  logback-spring.xml — structured logging configuration.

  MENTOR NOTE — fixing two v1.3 Logging findings at once:
    "No structured logging (MDC, JSON format) — logs are unstructured
    plaintext, impossible to query in ELK/CloudWatch."
    "No correlation ID / request ID — cannot trace a single request across
    multiple log lines."

  The `dev` profile keeps a human-readable console pattern (still including
  %X{requestId} so local debugging benefits from correlation too). The `prod`
  profile switches to one-JSON-object-per-line via logstash-logback-encoder,
  which any log aggregator (ELK, Loki, CloudWatch Logs Insights, Datadog) can
  parse and query directly — `requestId`, `level`, `logger`, and `message`
  all become independently filterable fields instead of being buried in a
  single unstructured text blob.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%X{requestId:-no-request}] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <customFields>{"application":"scms"}</customFields>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>
</configuration>
